# LLM 选择：openai 或 chatglm
LLM_PROVIDER=openai

# 通用 OpenAI 配置（模型对话 + 向量化默认使用）
OPENAI_API_KEY=your-openai-key
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# API 通道独立 key（可选，不填则回退到 OPENAI_API_KEY）
API_OPENAI_API_KEY=

# ChatGLM 兼容 OpenAI 接口的调用配置
CHATGLM_API_KEY=your-chatglm-api-key
CHATGLM_API_BASE=https://api.chatglm.cn/v1
CHATGLM_MODEL=glm-4
# API 通道独立 key（可选，不填则回退到 CHATGLM_API_KEY）
API_CHATGLM_API_KEY=

# Streamlit 通道独立 key（可选，不填则回退到 OPENAI_API_KEY / CHATGLM_API_KEY）
STREAMLIT_OPENAI_API_KEY=
STREAMLIT_CHATGLM_API_KEY=

# 目录与检索参数
CHROMA_PERSIST_DIR=storage/chroma
UPLOAD_DIR=storage/uploads
COLLECTION_NAME=chainknowledge
RETRIEVER_TOP_K=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=180
MEMORY_WINDOW=6
MAX_UPLOAD_SIZE_MB=40
MAX_RECENT_PAIRS=30

# 检索重排参数
RERANK_ENABLED=true
RERANK_TOP_K=4
RERANK_CANDIDATE_MULTIPLIER=3
RERANK_ALPHA=0.7
